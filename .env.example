# Copy to `.env` and fill in. NEVER commit your `.env`.

# === Database (PostgreSQL) ===
# Used by the docker-compose stack at the super-repo level.
POSTGRES_USER=forex
POSTGRES_PASSWORD=
POSTGRES_DB=forex
POSTGRES_HOST=postgres
POSTGRES_PORT=5432

# === Auth ===
# Bootstrap admin token for first-time setup. Strong random string.
ADMIN_API_KEY=

# === LLM providers (cascade) ===
GROQ_API_KEY=
GEMINI_API_KEY=
OPENROUTER_API_KEY=
CLOUDFLARE_API_TOKEN=
CLOUDFLARE_ACCOUNT_ID=
OLLAMA_BASE_URL=
OLLAMA_MODEL=nemotron-3-nano:4b

# === CORS — REQUIRED for production ===
# Comma-separated list of full origins (scheme + host + optional port) that
# are allowed to call this API from a browser. Falls back to localhost only.
TRUSTED_ORIGINS=http://localhost:8000,http://127.0.0.1:8000

# Where the auto-generated admin API key is written on first start.
# Defaults to /run/forex/admin.key (mode 0600). Falls back to ./admin.key
# if /run/forex isn't writable.
ADMIN_KEY_FILE=/run/forex/admin.key
